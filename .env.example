# Home Energy System — shared environment variables
# Copy this file to .env and fill in your values.
# Used by ALL services; loaded via:
#   load_dotenv(Path(__file__).parent.parent / ".env")

TZ=Europe/Amsterdam

# =============================================================================
# MariaDB
# =============================================================================
DB_HOST=192.168.x.x
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_TABLE=energy

# Root/admin credentials (MariaDB container + phpMyAdmin)
DB_RESOL_USER=root
DB_RESOL_PASSWORD=your_root_password

# =============================================================================
# MQTT broker
# =============================================================================
MQTT_BROKER=192.168.x.x
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password

# Service-specific topics
MQTT_BASE_TOPIC=rpi5new/                        # read_resol: sensor topic prefix
MQTT_OTTHING_TOPIC=otthing/XXXXXX/state         # read_otthing: OTThing state topic
MQTT_P60_TOPIC=sensor.your_p60_topic            # transfer_p60: Weheat P60 MQTT topic

# =============================================================================
# P1 smart meter (read_p1)
# =============================================================================
DSMR_URL=http://192.168.x.x/api/v2/sm/actual

# =============================================================================
# Resol VBus solar controller (read_resol)
# =============================================================================
VBUS_HOST=192.168.x.x
VBUS_PORT=7053
VBUS_PASSWORD=vbus

# =============================================================================
# BMW CarData API (read_bmw)
# Create a client at https://bmw-cardata.bmwgroup.com/customer
# Subscribe to scopes: cardata:api:read and cardata:streaming:read
# Note: BMW ConnectedDrive REST API was discontinued in September 2025.
# =============================================================================
BMW_CLIENT_ID=your_bmw_client_id
BMW_VIN=YOUR17CHARVIN0000

# =============================================================================
# PVOutput (read_growatt — optional upload to pvoutput.org)
# =============================================================================
PVOUTPUT_API_KEY=your_pvoutput_api_key
PVOUTPUT_SYSTEM_ID=your_pvoutput_system_id

# =============================================================================
# Home Assistant (battery_optimizer — EV smart plug control)
# =============================================================================
HA_URL=http://192.168.x.x:8123
HA_TOKEN=your_home_assistant_long_lived_token

# =============================================================================
# battery_optimizer — system location and contract dates
# =============================================================================

# Location for PV irradiance + weather forecasts (2 decimal places is sufficient)
SYSTEM_LAT=51.44
SYSTEM_LON=5.47

# BMW home location for EV at-home check (200 m radius)
BMW_HOME_LAT=51.44
BMW_HOME_LON=5.47

# Last day of MINIMIZE_EXPORT mode; DYNAMIC_PRICE activates the day after.
CONTRACT_END_DATE=2026-06-30

# Last day of net-metering (saldering); export price model changes after this.
SALDERING_END_DATE=2026-12-31

# =============================================================================
# battery_optimizer — dynamic energy tariffs incl. 21% VAT
# Update when your supplier changes tariffs; run update_fixed_costs.py after.
# =============================================================================
ELEC_INKOOPVERGOEDING_KWH=0.010000        # purchase surcharge EUR/kWh
ELEC_ENERGIEBELASTING_KWH=0.110848        # energy tax EUR/kWh
ELEC_VERKOOPVERGOEDING_KWH=0.010000       # feed-in surcharge EUR/kWh
GAS_INKOOPVERGOEDING_M3=0.082100
GAS_ENERGIEBELASTING_M3=0.726799

# Fixed costs per day incl. VAT (EUR/day)
ELEC_LEVERINGSKOSTEN_DAY=0.221918
GAS_LEVERINGSKOSTEN_DAY=0.213699
VERMINDERING_ENERGIEBELASTING_DAY=-1.723173
ELEC_SYSTEEMBEHEER_DAY=1.303654
GAS_SYSTEEMBEHEER_DAY=0.511346

# =============================================================================
# energy-agent — Claude AI advisor (not published)
# =============================================================================
CLAUDE_API_KEY=sk-ant-your_api_key_here
